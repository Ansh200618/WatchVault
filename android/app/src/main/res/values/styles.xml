<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/watchvault_background</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/watchvault_background</item>
        <item name="android:statusBarColor">@color/watchvault_background</item>
        <item name="android:navigationBarColor">@color/watchvault_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@color/watchvault_background</item>
        <item name="android:background">@color/watchvault_background</item>
        <item name="android:colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/watchvault_background</item>
        <item name="android:navigationBarColor">@color/watchvault_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@color/watchvault_background</item>
        <item name="android:background">@color/watchvault_background</item>
        <item name="android:statusBarColor">@color/watchvault_background</item>
        <item name="android:navigationBarColor">@color/watchvault_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
