<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">#070A0C</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">#070A0C</item>
        <item name="android:statusBarColor">#070A0C</item>
        <item name="android:navigationBarColor">#070A0C</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">#070A0C</item>
        <item name="android:background">#070A0C</item>
        <item name="android:colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">#070A0C</item>
        <item name="android:navigationBarColor">#070A0C</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="android:windowBackground">#070A0C</item>
        <item name="android:statusBarColor">#070A0C</item>
        <item name="android:navigationBarColor">#070A0C</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>